# Stage 1 - Build
FROM node:22 AS builder

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

# Stage 2 - Runtime
FROM node:22-alpine

# Create a non-root user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

COPY --from=builder /app .

# Give ownership to the non-root user
RUN chown -R appuser:appgroup /app

# Run as non-root
USER appuser

EXPOSE 3000

CMD ["npm", "start"]